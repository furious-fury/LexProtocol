# Database (matches docker-compose defaults)
DATABASE_URL=postgres://lexprotocol:lexprotocol@localhost:5432/lexprotocol?sslmode=disable

# EVM
RPC_URL=http://127.0.0.1:8545
RPC_HTTP_URL=http://127.0.0.1:8545
RPC_WS_URL=ws://127.0.0.1:8545
CHAIN_ID=31337
ORACLE_ADDRESS=
ORACLE_REGISTRY_ADDRESS=
SIGNATURE_TTL_SECONDS=300
PRICING_HTTP_ADDR=:8080
MARKET_FACTORY_ADDRESS=
START_BLOCK=0
INDEXER_CONFIRMATIONS=2
INDEXER_HTTP_ADDR=:8090

# Do not store deployer private keys in .env files.
# For contract deploys, export PRIVATE_KEY in your terminal session instead.
# For pricing signatures, export PRICING_SIGNER_PRIVATE_KEY in your terminal session instead.

# Monad testnet
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_TESTNET_CHAIN_ID=10143

# Optional Redis (enable with: docker compose --profile redis up -d)
REDIS_URL=redis://localhost:6379
